local ParticlesActive = true
local ParticlesFolder = Instance.new("Folder", MainFrame)
spawn(function()
    while true do
        if ParticlesActive then
            for i = 1, 2 do 
                local p = Instance.new("Frame", ParticlesFolder)
                p.BorderSizePixel = 0
                p.BackgroundColor3 = UIStroke.Color
                p.Size = UDim2.new(0, 2, 0, 2)
                local startX = math.random()
                p.Position = UDim2.new(startX, 0, -0.02, 0)
                p.BackgroundTransparency = math.random(2, 6) / 10
                local speed = math.random(3, 6)
                p:TweenPosition(UDim2.new(startX, 0, 1.02, 0), "In", "Linear", speed)
                task.delay(speed, function() p:Destroy() end)
            end
        end
        task.wait(0.06)
    end
end)

