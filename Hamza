local colors = {["Cyan"] = Color3.fromRGB(0, 255, 255), ["Red"] = Color3.fromRGB(255, 50, 50), ["Green"] = Color3.fromRGB(50, 255, 50)}
local sy = 0.35
for name, col in pairs(colors) do
    CreateSetBtn("Color: "..name, UDim2.new(0.075, 0, sy, 0), function()
        UIStroke.Color = col
        S_UIStroke.Color = col
        ButtonStroke.Color = col
        Title.TextColor3 = col
        ScrollingFrame.ScrollBarImageColor3 = col
        for _, card in pairs(ScrollingFrame:GetChildren()) do
            if card:IsA("Frame") then card:FindFirstChildOfClass("UIStroke").Color = col end
        end
    end)
    sy = sy + 0.15
end

