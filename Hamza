local function AddScriptCard(Name, ScriptCode)
    local Card = Instance.new("Frame")
    local CardStroke = Instance.new("UIStroke")
    local NameLabel = Instance.new("TextLabel")
    local ExecuteBtn = Instance.new("TextButton")

    Card.Name = Name
    Card.Parent = ScrollingFrame
    Card.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
    Card.Size = UDim2.new(1, -20, 0, 75) 
    Instance.new("UICorner", Card).CornerRadius = UDim.new(0, 12)
    
    CardStroke.Parent = Card
    CardStroke.Thickness = 1.5
    CardStroke.Color = UIStroke.Color

    NameLabel.Parent = Card
    NameLabel.BackgroundTransparency = 1
    NameLabel.Position = UDim2.new(0.05, 0, 0, 0)
    NameLabel.Size = UDim2.new(0.6, 0, 1, 0)
    NameLabel.Font = Enum.Font.GothamBold
    NameLabel.Text = Name:upper()
    NameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    NameLabel.TextSize = 16
    NameLabel.TextXAlignment = Enum.TextXAlignment.Left

    ExecuteBtn.Parent = Card
    ExecuteBtn.BackgroundColor3 = Color3.fromRGB(220, 0, 0)
    ExecuteBtn.Position = UDim2.new(0.65, 0, 0.22, 0)
    ExecuteBtn.Size = UDim2.new(0, 110, 0, 42)
    ExecuteBtn.Text = "EXECUTE"
    ExecuteBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    ExecuteBtn.Font = Enum.Font.GothamBold
    ExecuteBtn.TextSize = 13
    Instance.new("UICorner", ExecuteBtn).CornerRadius = UDim.new(0, 8)

    ExecuteBtn.MouseButton1Click:Connect(function()
        loadstring(game:HttpGet(ScriptCode))()
    end)
end

