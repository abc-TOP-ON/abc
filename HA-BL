local ProtectionSystem = {
    Enabled = false,
    AntiLogging = true,
    AntiPing = true,
    AntiRejoin = true,
    PerformanceMode = true,
    AntiHDAdmin = true  -- حماية جديدة ضد HD Admin
}

-- دالة حماية ضد HD Admin
local function AntiHDAdminProtection()
    if not ProtectionSystem.AntiHDAdmin then return end
    
    -- حماية متقدمة ضد HD Admin
    local function BlockHDAdminCommands()
        -- منع جميع أوامر HD Admin
        local ReplicatedStorage = game:GetService("ReplicatedStorage")
        local Players = game:GetService("Players")
        local LocalPlayer = Players.LocalPlayer
        
        -- حماية ضد الأوامر المرسلة
        local originalIndex; originalIndex = hookmetamethod(game, "__namecall", function(self, ...)
            local method = getnamecallmethod()
            local args = {...}
            
            -- منع أي أمر يحتوي على HD Admin
            if tostring(self):find("HDAdmin") or 
               (method == "FireServer" and tostring(self):find("Admin")) or
               (method == "InvokeServer" and tostring(self):find("Admin")) then
                return nil
            end
            
            -- منع الرسائل المرتبطة بـ HD Admin
            for _, arg in pairs(args) do
                if type(arg) == "string" and arg:find("HDAdmin") then
                    return nil
                end
            end
            
            return originalIndex(self, ...)
        end)
        
        -- حماية ضد الأحداث
        local function ProtectRemoteEvents()
            for _, obj in pairs(ReplicatedStorage:GetDescendants()) do
                if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
                    if obj.Name:find("HDAdmin") or obj.Name:find("AdminCommand") then
                        pcall(function()
                            obj:Destroy()
                        end)
                    end
                end
            end
        end
        
        -- مراقبة مستمرة
        ReplicatedStorage.DescendantAdded:Connect(function(child)
            if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
                if child.Name:find("HDAdmin") or child.Name:find("AdminCommand") then
                    task.wait(0.1)
                    pcall(function()
                        child:Destroy()
                    end)
                end
            end
        end)
        
        ProtectRemoteEvents()
    end
    
    -- حماية ضد كشف السكربتات
    local old; old = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        if tostring(self):find("HDAdmin") and (method == "FireServer" or method == "InvokeServer") then
            return nil
        end
        return old(self, ...)
    end)
    
    -- حماية ضد عمليات المسح
    for _, v in pairs(game:GetService("Players").LocalPlayer.PlayerGui:GetChildren()) do
        if v.Name:find("HDAdmin") or v.Name:find("AntiCheat") or v.Name:find("Admin") then
            v:Destroy()
        end
    end
    
    -- حماية لواجهة اللاعب
    for _, v in pairs(game:GetService("Players"):GetPlayers()) do
        if v ~= game.Players.LocalPlayer then
            pcall(function()
                if v.PlayerGui then
                    for _, gui in pairs(v.PlayerGui:GetChildren()) do
                        if gui.Name:find("HDAdmin") or gui.Name:find("Admin") then
                            gui:Destroy()
                        end
                    end
                end
            end)
        end
    end
    
    -- مراقبة الإضافات الجديدة
    game:GetService("Players").LocalPlayer.PlayerGui.ChildAdded:Connect(function(child)
        if child.Name:find("HDAdmin") or child.Name:find("AntiCheat") or child.Name:find("Admin") then
            task.wait(0.1)
            child:Destroy()
        end
    end)
    
    -- تنفيذ الحماية المتقدمة
    BlockHDAdminCommands()
    
    print("✅ تم تفعيل الحماية الكاملة ضد HD Admin وأوامره")
end

local function EnableProtection()
    if ProtectionSystem.Enabled then return end
    
    ProtectionSystem.Enabled = true
    
    -- حماية ضد الـ Logging
    if ProtectionSystem.AntiLogging then
        local originalPrint = print
        print = function(...)
            if not string.find(debug.traceback(), "OrionLib") then
                originalPrint("[Protected]: " .. tostring(...))
            end
        end
    end
    
    -- حماية ضد الـ Ping العالي
    if ProtectionSystem.AntiPing then
        game:GetService("NetworkClient").ChildAdded:Connect(function(child)
            task.wait(0.1)
        end)
    end
    
    -- حماية ضد HD Admin
    if ProtectionSystem.AntiHDAdmin then
        AntiHDAdminProtection()
    end
    
    -- تحسين الأداء
    if ProtectionSystem.PerformanceMode then
        settings().Rendering.QualityLevel = 1
        game:GetService("Workspace").StreamingEnabled = true
    end
    
    return true
end

local function DisableProtection()
    ProtectionSystem.Enabled = false
    return true
end

