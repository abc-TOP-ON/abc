            BackgroundColor3 = Color3.fromRGB(200, 0, 50),
            Size = UDim2.new(0, 150, 0, 45)
        }):Play()
    end)
    
    -- دالة التحقق من المفتاح
    local function VerifyKey()
        local enteredKey = KeyBox.Text
        
        if enteredKey == CorrectKey then
            keyVerified = true
            Status.Text = "✅ المفتاح صحيح! جاري التحميل..."
            Status.TextColor3 = Color3.fromRGB(0, 255, 100)
            
            SubmitBtn.Text = "✅ تم"
            
            -- تأثير نجاح
            TweenService:Create(MainFrame, TweenInfo.new(0.3), {
                BackgroundColor3 = Color3.fromRGB(0, 50, 20)
            }):Play()
            
            -- إغلاق واجهة المفتاح بعد تأخير قصير
            task.wait(1.5)
            KeyGui:Destroy()
            return true
        else
            attempts = attempts + 1
            local remaining = maxAttempts - attempts
            
            if remaining > 0 then
                Status.Text = "❌ مفتاح خاطئ! المحاولات المتبقية: " .. remaining
                Status.TextColor3 = Color3.fromRGB(255, 100, 100)
                KeyBox.Text = ""
                
                -- تأثير خطأ
                TweenService:Create(KeyBox, TweenInfo.new(0.1), {
                    BackgroundColor3 = Color3.fromRGB(80, 20, 20)
                }):Play()
                task.wait(0.1)
                TweenService:Create(KeyBox, TweenInfo.new(0.1), {
                    BackgroundColor3 = Color3.fromRGB(30, 25, 35)
                }):Play()
            else
                Status.Text = "⛔ تم حظر الوصول!"
                Status.TextColor3 = Color3.fromRGB(255, 50, 50)
                SubmitBtn.Text = "🚫 محظور"
                SubmitBtn.Active = false
                SubmitBtn.BackgroundColor3 = Color3.fromRGB(100, 0, 0)
                
                TweenService:Create(MainFrame, TweenInfo.new(0.3), {
                    BackgroundColor3 = Color3.fromRGB(50, 0, 0)
                }):Play()
            end
            return false
        end
    end
    
    -- أحداث الزر
    SubmitBtn.MouseButton1Click:Connect(VerifyKey)
    
    KeyBox.FocusLost:Connect(function(enterPressed)
        if enterPressed then
            VerifyKey()
        end
    end)
    
    -- تأثير الظهور
    MainFrame.Size = UDim2.new(0, 0, 0, 280)
    MainFrame.Position = UDim2.new(0.5, 0, 0.5, -140)
    
    TweenService:Create(MainFrame, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, 420, 0, 280),
        Position = UDim2.new(0.5, -210, 0.5, -140)
    }):Play()
    
    -- إمكانية سحب النافذة
    local dragging = false
    local dragInput, dragStart, startPos
    
    TitleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = MainFrame.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    
    TitleBar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            dragInput = input
        end
    end)
    
    game:GetService("UserInputService").InputChanged:Connect(function(input)
        if dragging and input == dragInput then
            local delta = input.Position - dragStart
            MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    
    -- إغلاق عند ESC
    local escConnection
    escConnection = game:GetService("UserInputService").InputBegan:Connect(function(input)
        if input.KeyCode == Enum.KeyCode.Escape then
            escConnection:Disconnect()
            if not keyVerified then
                TweenService:Create(MainFrame, TweenInfo.new(0.3), {
                    Size = UDim2.new(0, 0, 0, 280),
                    Position = UDim2.new(0.5, 0, 0.5, -140)
                }):Play()
                task.wait(0.3)
                KeyGui:Destroy()
            end
        end
    end)
    
    -- الانتظار حتى يتم التحقق
    repeat task.wait() until keyVerified or attempts >= maxAttempts
    
    return keyVerified
end

