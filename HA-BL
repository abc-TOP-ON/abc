local SpeedSystem = {
    CurrentSpeed = 20,
    MaxSpeed = 500,
    MinSpeed = 20,
    OriginalSpeed = 20
}

local JumpSystem = {
    CurrentPower = 50,
    MaxPower = 500,
    MinPower = 20,
    OriginalPower = 50
}

local function ApplySpeed(value)
    SpeedSystem.CurrentSpeed = math.clamp(value, SpeedSystem.MinSpeed, SpeedSystem.MaxSpeed)
    local character = game.Players.LocalPlayer.Character
    if character and character:FindFirstChild("Humanoid") then
        character.Humanoid.WalkSpeed = SpeedSystem.CurrentSpeed
    end
end

local function ApplyJumpPower(value)
    JumpSystem.CurrentPower = math.clamp(value, JumpSystem.MinPower, JumpSystem.MaxPower)
    local character = game.Players.LocalPlayer.Character
    if character and character:FindFirstChild("Humanoid") then
        character.Humanoid.JumpPower = JumpSystem.CurrentPower
    end
end

