local function sendMsg(msg)
    pcall(function()
        if T.ChatVersion == Enum.ChatVersion.TextChatService then
            T.TextChannels.RBXGeneral:SendAsync(msg)
        else
            local r = R:FindFirstChild("SayMessageRequest", true) or R:FindFirstChild("ChatEvent", true)
            if r then r:FireServer(msg, "All") end
        end
    end)
end

