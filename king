    content.Visible = not isMinimized
    title.Visible = not isMinimized
    selectPanel.Visible = false
    if isMinimized then
        main:TweenSize(UDim2.new(0, 40, 0, 40), "Out", "Quart", 0.3, true)
        closeBtn.Text = "+" closeBtn.Position = UDim2.new(0, 7, 0, 7)
