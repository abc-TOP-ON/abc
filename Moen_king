-- وظيفة تشغيل السكربت من رابط
local function AddScriptFromURL(Name, ScriptURL)
    local ButtonFrame = Instance.new("Frame")
    local BtnStroke = Instance.new("UIStroke")
    local ScriptName = Instance.new("TextLabel")
    local ExecuteBtn = Instance.new("TextButton")

    ButtonFrame.Size = UDim2.new(0, 310, 0, 70)
    ButtonFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    ButtonFrame.Parent = ScrollingFrame
    Instance.new("UICorner", ButtonFrame).CornerRadius = UDim.new(0, 10)
    BtnStroke.Parent = ButtonFrame
    BtnStroke.Thickness = 2
    
    ScriptName.Parent = ButtonFrame
    ScriptName.Size = UDim2.new(0.6, 0, 1, 0)
    ScriptName.Position = UDim2.new(0.05, 0, 0, 0)
    ScriptName.BackgroundTransparency = 1
    ScriptName.Text = Name
    ScriptName.TextColor3 = Color3.fromRGB(255, 255, 255)
    ScriptName.Font = Enum.Font.GothamBold
    ScriptName.TextSize = 14
    ScriptName.TextXAlignment = Enum.TextXAlignment.Left

    ExecuteBtn.Parent = ButtonFrame
    ExecuteBtn.Size = UDim2.new(0, 85, 0, 35)
    ExecuteBtn.Position = UDim2.new(0.68, 0, 0.25, 0)
    ExecuteBtn.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
    ExecuteBtn.Text = "EXECUTE"
    ExecuteBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    ExecuteBtn.Font = Enum.Font.GothamBold
    ExecuteBtn.TextSize = 11
    Instance.new("UICorner", ExecuteBtn).CornerRadius = UDim.new(0, 8)

    -- تشغيل السكربت عند الضغط
    ExecuteBtn.MouseButton1Click:Connect(function()
        loadstring(game:HttpGet(ScriptURL))()
    end)

    task.spawn(function()
        local h = 0
        while task.wait(0.01) do
            h = h + 1/255
            if h > 1 then h = 0 end
            BtnStroke.Color = Color3.fromHSV(h, 0.8, 1)
        end
    end)
end

